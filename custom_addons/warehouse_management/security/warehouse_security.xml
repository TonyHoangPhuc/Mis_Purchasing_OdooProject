<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_warehouse_management" model="ir.module.category">
        <field name="name">Quản lý kho</field>
        <field name="sequence">25</field>
    </record>

    <record id="privilege_warehouse_management" model="res.groups.privilege">
        <field name="name">Kho</field>
        <field name="category_id" ref="module_category_warehouse_management"/>
        <field name="sequence">25</field>
    </record>

    <record id="group_receiving_qc_user" model="res.groups">
        <field name="name">Nhân viên QC nhập kho</field>
        <field name="privilege_id" ref="privilege_warehouse_management"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_receiving_qc_manager" model="res.groups">
        <field name="name">Quản lý QC nhập kho</field>
        <field name="privilege_id" ref="privilege_warehouse_management"/>
        <field name="implied_ids" eval="[(4, ref('group_receiving_qc_user')), (4, ref('stock.group_stock_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
