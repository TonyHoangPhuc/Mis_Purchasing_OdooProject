<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_tree_store_delivery_supply_chain" model="ir.ui.view">
        <field name="name">stock.picking.tree.store.delivery.supply.chain</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list default_order="scheduled_date desc">
                <field name="name"/>
                <field name="origin" string="PR nguồn"/>
                <field name="location_id"/>
                <field name="location_dest_id"/>
                <field name="scheduled_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_picking_search_store_delivery_supply_chain" model="ir.ui.view">
        <field name="name">stock.picking.search.store.delivery.supply.chain</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="origin"/>
                <filter name="waiting_delivery" string="Chờ giao hàng" domain="[('state', 'not in', ['done', 'cancel'])]"/>
                <filter name="done_delivery" string="Đã giao" domain="[('state', '=', 'done')]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="Trạng thái" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_picking_form_inherit_supply_chain_management" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.supply.chain.management</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="invisible">scm_is_store_delivery</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Chuỗi cung ứng" invisible="not scm_allocation_plan_id">
                    <group>
                        <field name="scm_allocation_plan_id" readonly="1"/>
                    </group>
                </page>
                <page string="Đơn cần giao cửa hàng" invisible="not scm_is_store_delivery">
                    <group>
                        <group>
                            <field name="origin" string="PR nguồn" readonly="1"/>
                        </group>
                        <group>
                            <field name="location_id" readonly="1"/>
                            <field name="location_dest_id" readonly="1"/>
                            <field name="scheduled_date" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_supply_chain_store_deliveries" model="ir.actions.act_window">
        <field name="name">Đơn cần giao cửa hàng</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_picking_tree_store_delivery_supply_chain"/>
        <field name="search_view_id" ref="view_picking_search_store_delivery_supply_chain"/>
        <field name="domain">[('picking_type_code', '=', 'internal'), ('location_id.warehouse_id.mis_role', '=', 'central'), ('location_dest_id.warehouse_id.mis_role', '=', 'store'), ('state', 'not in', ['done', 'cancel'])]</field>
        <field name="context">{'search_default_waiting_delivery': 1, 'create': False}</field>
    </record>
</odoo>
