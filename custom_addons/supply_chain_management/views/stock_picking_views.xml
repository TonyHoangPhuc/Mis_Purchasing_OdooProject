<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_supply_chain_management" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.supply.chain.management</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Chuỗi cung ứng" invisible="not scm_allocation_plan_id">
                    <group>
                        <field name="scm_allocation_plan_id" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
