<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_supply_chain_allocation_plan_tree" model="ir.ui.view">
        <field name="name">supply.chain.allocation.plan.tree</field>
        <field name="model">supply.chain.allocation.plan</field>
        <field name="arch" type="xml">
            <list default_order="planned_date desc">
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="source_location_id"/>
                <field name="planned_date"/>
                <field name="state"/>
                <field name="transfer_count"/>
            </list>
        </field>
    </record>

    <record id="view_supply_chain_allocation_plan_form" model="ir.ui.view">
        <field name="name">supply.chain.allocation.plan.form</field>
        <field name="model">supply.chain.allocation.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_generate_suggestions"
                        type="object"
                        string="Tạo đề xuất"
                        class="oe_highlight"
                        invisible="state == 'confirmed' or state == 'cancelled'"
                    />
                    <button
                        name="action_create_internal_transfers"
                        type="object"
                        string="Tạo điều chuyển"
                        class="btn-primary"
                        invisible="state != 'suggested'"
                    />
                    <button
                        name="action_reset_to_draft"
                        type="object"
                        string="Đặt lại nháp"
                        invisible="state == 'draft'"
                    />
                    <button
                        name="action_cancel"
                        type="object"
                        string="Hủy"
                        class="btn-secondary"
                        invisible="state == 'cancelled'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,suggested,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transfers" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="transfer_count" widget="statinfo" string="Điều chuyển"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="warehouse_id"/>
                            <field name="source_location_id"/>
                            <field name="picking_type_id"/>
                        </group>
                        <group>
                            <field name="planned_date"/>
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng phân bổ">
                            <field name="line_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="partner_id"/>
                                    <field name="destination_location_id"/>
                                    <field name="product_id"/>
                                    <field name="priority"/>
                                    <field name="on_hand_qty"/>
                                    <field name="min_qty"/>
                                    <field name="max_qty"/>
                                    <field name="demand_qty"/>
                                    <field name="suggested_qty"/>
                                    <field name="shortage_qty"/>
                                    <field name="transfer_picking_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú">
                            <field name="note" placeholder="Nhập ghi chú kế hoạch hoặc giả định phân bổ..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_supply_chain_allocation_plan_search" model="ir.ui.view">
        <field name="name">supply.chain.allocation.plan.search</field>
        <field name="model">supply.chain.allocation.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="source_location_id"/>
                <filter name="suggested" string="Đã đề xuất" domain="[('state', '=', 'suggested')]"/>
                <filter name="confirmed" string="Đã xác nhận" domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <group>
                    <filter name="group_warehouse" string="Kho" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                    <filter name="group_state" string="Trạng thái" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_supply_chain_allocation_plans" model="ir.actions.act_window">
        <field name="name">Kế hoạch phân bổ</field>
        <field name="res_model">supply.chain.allocation.plan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_supply_chain_allocation_plan_search"/>
    </record>

    <menuitem
        id="menu_supply_chain_root"
        name="SupplyChain"
        sequence="40"
        groups="supply_chain_management.group_supply_chain_user"
    />
    <menuitem
        id="menu_supply_chain_plans"
        name="Allocation Plans"
        parent="supply_chain_management.menu_supply_chain_root"
        action="supply_chain_management.action_supply_chain_allocation_plans"
        sequence="10"
        groups="supply_chain_management.group_supply_chain_user"
    />
    <menuitem
        id="menu_supply_chain_store_deliveries"
        name="Don can giao cua hang"
        parent="supply_chain_management.menu_supply_chain_root"
        action="supply_chain_management.action_supply_chain_store_deliveries"
        sequence="20"
        groups="supply_chain_management.group_supply_chain_user"
    />
    <menuitem
        id="menu_supply_chain_rules"
        name="Allocation Rules"
        parent="supply_chain_management.menu_supply_chain_root"
        action="supply_chain_management.action_supply_chain_allocation_rules"
        sequence="30"
        groups="supply_chain_management.group_supply_chain_user"
    />
</odoo>
