<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_supply_chain_management" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.supply.chain.management</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Chuỗi cung ứng">
                    <group>
                        <field name="sc_is_store"/>
                        <field name="sc_store_priority" invisible="not sc_is_store"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
