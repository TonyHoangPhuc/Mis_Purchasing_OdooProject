<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_supply_chain_allocation_rule_tree" model="ir.ui.view">
        <field name="name">supply.chain.allocation.rule.tree</field>
        <field name="model">supply.chain.allocation.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="warehouse_id"/>
                <field name="location_id"/>
                <field name="product_id"/>
                <field name="store_priority"/>
                <field name="min_qty"/>
                <field name="max_qty"/>
                <field name="current_qty"/>
                <field name="replenishment_need_qty"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_supply_chain_allocation_rule_form" model="ir.ui.view">
        <field name="name">supply.chain.allocation.rule.form</field>
        <field name="model">supply.chain.allocation.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="warehouse_id"/>
                            <field name="location_id"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="store_priority" readonly="1"/>
                            <field name="min_qty"/>
                            <field name="max_qty"/>
                            <field name="current_qty" readonly="1"/>
                            <field name="replenishment_need_qty" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_supply_chain_allocation_rule_search" model="ir.ui.view">
        <field name="name">supply.chain.allocation.rule.search</field>
        <field name="model">supply.chain.allocation.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="warehouse_id"/>
                <field name="product_id"/>
                <filter name="priority_high" string="Ưu tiên cao" domain="[('store_priority', '=', 'high')]"/>
                <filter name="needs_replenishment" string="Cần bổ sung hàng" domain="[('replenishment_need_qty', '>', 0)]"/>
                <separator/>
                <group>
                    <filter name="group_warehouse" string="Kho" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                    <filter name="group_store" string="Cửa hàng" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_priority" string="Mức ưu tiên" domain="[]" context="{'group_by': 'store_priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_supply_chain_allocation_rules" model="ir.actions.act_window">
        <field name="name">Allocation Rules</field>
        <field name="res_model">supply.chain.allocation.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_supply_chain_allocation_rule_search"/>
    </record>
</odoo>
