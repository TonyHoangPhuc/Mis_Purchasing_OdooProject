<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_supply_chain_management" model="ir.module.category">
        <field name="name">Supply Chain Management</field>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_supply_chain_management" model="res.groups.privilege">
        <field name="name">Supply Chain Management</field>
        <field name="category_id" ref="module_category_supply_chain_management"/>
        <field name="sequence">30</field>
    </record>

    <record id="group_supply_chain_user" model="res.groups">
        <field name="name">Supply Chain User</field>
        <field name="privilege_id" ref="privilege_supply_chain_management"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_supply_chain_manager" model="res.groups">
        <field name="name">Supply Chain Manager</field>
        <field name="privilege_id" ref="privilege_supply_chain_management"/>
        <field name="implied_ids" eval="[(4, ref('group_supply_chain_user')), (4, ref('stock.group_stock_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
