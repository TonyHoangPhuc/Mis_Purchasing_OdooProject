<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_store_management" model="ir.module.category">
        <field name="name">Quản lý cửa hàng</field>
        <field name="sequence">35</field>
    </record>

    <record id="privilege_store_management" model="res.groups.privilege">
        <field name="name">Cửa hàng</field>
        <field name="category_id" ref="module_category_store_management"/>
        <field name="sequence">35</field>
    </record>

    <record id="group_store_user" model="res.groups">
        <field name="name">Nhân viên cửa hàng</field>
        <field name="privilege_id" ref="privilege_store_management"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user')), (4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_store_manager" model="res.groups">
        <field name="name">Quản lý cửa hàng</field>
        <field name="privilege_id" ref="privilege_store_management"/>
        <field name="implied_ids" eval="[(4, ref('group_store_user')), (4, ref('stock.group_stock_manager')), (4, ref('sales_team.group_sale_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
