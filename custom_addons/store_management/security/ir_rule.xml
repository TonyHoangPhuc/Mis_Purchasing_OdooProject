    <record id="rule_stock_move_central" model="ir.rule">
        <field name="name">Kho tổng: Chỉ xem chi tiết di chuyển liên quan đến Kho tổng</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="domain_force">[
            '|', '|',
