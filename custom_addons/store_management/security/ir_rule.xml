<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Các bộ lọc cho Cửa hàng (Store Warehouse) -->
    
    <record id="rule_stock_picking_store" model="ir.rule">
        <field name="name">Cửa hàng: Chỉ xem phiếu giao nhận liên quan đến Cửa hàng</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[
            '|', '|',
            ('picking_type_id.warehouse_id.mis_role', '=', 'store'),
            ('location_id.warehouse_id.mis_role', '=', 'store'),
            ('location_dest_id.warehouse_id.mis_role', '=', 'store')
        ]</field>
        <field name="groups" eval="[(4, ref('store_management.group_store_user'))]"/>
    </record>

    <record id="rule_stock_move_store" model="ir.rule">
        <field name="name">Cửa hàng: Chỉ xem chi tiết di chuyển liên quan đến Cửa hàng</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="domain_force">[
            '|', '|',
            ('picking_type_id.warehouse_id.mis_role', '=', 'store'),
            ('location_id.warehouse_id.mis_role', '=', 'store'),
            ('location_dest_id.warehouse_id.mis_role', '=', 'store')
        ]</field>
        <field name="groups" eval="[(4, ref('store_management.group_store_user'))]"/>
    </record>

    <record id="rule_stock_move_line_store" model="ir.rule">
        <field name="name">Cửa hàng: Chỉ xem dòng di chuyển liên quan đến Cửa hàng</field>
        <field name="model_id" ref="stock.model_stock_move_line"/>
        <field name="domain_force">[
            '|', '|',
            ('picking_type_id.warehouse_id.mis_role', '=', 'store'),
            ('location_id.warehouse_id.mis_role', '=', 'store'),
            ('location_dest_id.warehouse_id.mis_role', '=', 'store')
        ]</field>
        <field name="groups" eval="[(4, ref('store_management.group_store_user'))]"/>
    </record>

    <record id="rule_stock_quant_store" model="ir.rule">
        <field name="name">Cửa hàng: Chỉ xem Tồn kho của Cửa hàng (và các vị trí trung chuyển, NCC, khách hàng)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="domain_force">[
            '|',
            ('location_id.usage', '!=', 'internal'),
            ('location_id.warehouse_id.mis_role', '=', 'store')
        ]</field>
        <field name="groups" eval="[(4, ref('store_management.group_store_user'))]"/>
    </record>

