    <record id="rule_stock_quant_central" model="ir.rule">
        <field name="name">Kho tổng: Chỉ xem Tồn kho của Kho tổng (và các vị trí trung chuyển, NCC, khách hàng)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="domain_force">[
            '|',
            ('location_id.usage', '!=', 'internal'),
            ('location_id.warehouse_id.mis_role', '=', 'central')
        ]</field>
        <field name="groups" eval="[(4, ref('warehouse_management.group_receiving_qc_user'))]"/>
    </record>

</odoo>
