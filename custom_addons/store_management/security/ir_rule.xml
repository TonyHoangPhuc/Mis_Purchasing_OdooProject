        ]</field>
        <field name="groups" eval="[(4, ref('warehouse_management.group_receiving_qc_user'))]"/>
    </record>

    <record id="rule_stock_move_line_central" model="ir.rule">
        <field name="name">Kho tổng: Chỉ xem dòng di chuyển liên quan đến Kho tổng</field>
