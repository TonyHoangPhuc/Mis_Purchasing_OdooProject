    <record id="view_picking_form_inherit_store_discrepancy_actions" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.store.discrepancy.actions</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="store_management.view_picking_form_inherit_discrepancy"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='%(store_management.action_mer_delivery_discrepancy_wizard)d']" position="attributes">
                <attribute name="string">Kiểm hàng thực tế</attribute>
                <attribute name="invisible">state in ('done', 'cancel') or picking_type_code not in ('internal', 'incoming')</attribute>
            </xpath>
            <xpath expr="//button[@name='%(store_management.action_mer_excess_receipt)d']" position="replace">
                <button name="action_view_store_discrepancy_reports"
                        string="Xem báo cáo sai lệch"
                        type="object"
                        invisible="picking_type_code not in ('internal', 'incoming')"
                        groups="store_management.group_store_user"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_form_inherit_store_receipt_flow" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.store.receipt.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="warehouse_management.view_picking_form_inherit_warehouse_management"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='do_print_picking']" position="attributes">
                <attribute name="invisible">wm_is_incoming_receipt or state != 'assigned'</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.action_report_delivery)d']" position="attributes">
                <attribute name="invisible">wm_is_incoming_receipt or state != 'done'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="invisible">wm_is_incoming_receipt or state not in ('assigned', 'confirmed', 'draft', 'waiting')</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.act_stock_return_picking)d']" position="attributes">
                <attribute name="invisible">store_route_type == 'supplier_to_store' or state != 'done'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_start_qc']" position="attributes">
                <attribute name="invisible">not wm_is_incoming_receipt or store_route_type in ['supplier_to_store', 'supplier_to_central', 'central_to_store'] or wm_qc_status != 'draft' or state == 'cancel'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_qc_pass']" position="attributes">
                <attribute name="invisible">not wm_is_incoming_receipt or store_route_type in ['supplier_to_store', 'supplier_to_central', 'central_to_store'] or wm_qc_status != 'checking' or state == 'cancel'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_qc_reject']" position="attributes">
                <attribute name="invisible">not wm_is_incoming_receipt or store_route_type in ['supplier_to_store', 'supplier_to_central', 'central_to_store'] or wm_qc_status != 'checking' or state == 'cancel'</attribute>
            </xpath>
            <xpath expr="//field[@name='wm_qc_note']" position="after">
                <field name="store_receipt_issue_type" readonly="1"/>
                <field name="store_rejected_return_picking_id" readonly="1" invisible="not store_rejected_return_picking_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_form_inherit_store_receipt_only_actual_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.store.receipt.only.actual.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="store_management.view_picking_form_inherit_store_discrepancy_actions"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_store_discrepancy_reports']" position="attributes">
                <attribute name="invisible">store_receipt_issue_type not in ['shortage', 'overage', 'mixed', 'damaged_partial', 'damaged_rejected']</attribute>
            </xpath>
            <xpath expr="//button[@name='%(store_management.action_mer_delivery_discrepancy_wizard)d']" position="attributes">
                <attribute name="invisible">not wm_is_incoming_receipt or state in ('done', 'cancel')</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_warehouse_form_inherit_store_management" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.store.management</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="mis_role" string="Vai trò" widget="radio" options="{'horizontal': true}"/>
            </xpath>
        </field>
    </record>

    <record id="view_mer_discrepancy_report_form_inherit_store" model="ir.ui.view">
        <field name="name">mer.discrepancy.report.form.inherit.store</field>
        <field name="model">mer.discrepancy.report</field>
        <field name="inherit_id" ref="merchandise_management.view_mer_discrepancy_report_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_submit"
                        string="Gửi Merchandise"
                        type="object"
                        class="btn-primary"
                        groups="store_management.group_store_user"
                        invisible="state != 'draft' or submitted_to_merchandise"/>
                <button name="action_create_replenishment_pr"
                        string="Tạo PR bù hàng"
                        type="object"
                        class="btn-primary"
                        groups="merchandise_management.group_merchandise_user"
                        invisible="reason != 'shortage' or replenishment_request_id or state != 'draft' or not submitted_to_merchandise"/>
                <field name="submitted_to_merchandise" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_create_replenishment_po']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_create_return_picking']" position="attributes">
                <attribute name="invisible">reason != 'overage' or return_picking_id or state != 'draft' or not purchase_id</attribute>
            </xpath>
            <xpath expr="//field[@name='purchase_id']" position="before">
                <field name="picking_id"/>
                <field name="mer_request_id" readonly="1"/>
                <field name="source_route_label" readonly="1"/>
                <field name="handling_status" readonly="1"/>
                <field name="replenishment_request_id" readonly="1" invisible="not replenishment_request_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_mer_discrepancy_report_tree_inherit_store" model="ir.ui.view">
        <field name="name">mer.discrepancy.report.tree.inherit.store</field>
        <field name="model">mer.discrepancy.report</field>
        <field name="inherit_id" ref="merchandise_management.view_mer_discrepancy_report_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="sample">0</attribute>
            </xpath>
            <xpath expr="//field[@name='date_discrepancy']" position="after">
                <field name="picking_id" optional="show"/>
                <field name="mer_request_id" optional="show"/>
                <field name="source_route_label" optional="show"/>
                <field name="handling_status" optional="show"/>
                <field name="replenishment_request_id" optional="show"/>
                <field name="submitted_to_merchandise" optional="show"/>
            </xpath>
        </field>
    </record>

