<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_store_link" model="ir.ui.view">
        <field name="name">account.move.form.inherit.store.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="store_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="account.menu_action_account_payments_payable" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_action_move_in_invoice_type" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_finance_receivables" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_finance_entries" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="view_store_vendor_bill_list" model="ir.ui.view">
        <field name="name">store.vendor.bill.list</field>
        <field name="model">store.vendor.bill</field>
        <field name="arch" type="xml">
            <list string="Hóa đơn Nhà cung cấp">
                <field name="name" decoration-bf="1"/>
                <field name="date_bill"/>
                <field name="purchase_id"/>
                <field name="partner_id"/>
                <field name="store_id"/>
                <field name="amount_total" sum="Tổng tiền"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_store_vendor_bill_form" model="ir.ui.view">
        <field name="name">store.vendor.bill.form</field>
        <field name="model">store.vendor.bill</field>
        <field name="arch" type="xml">
            <form string="Hóa đơn Nhà cung cấp">
                <header>
                    <button name="action_confirm" string="Xác nhận" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_bill"/>
                            <field name="purchase_id"/>
                            <field name="invoice_origin"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="mer_request_id"/>
                            <field name="store_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="amount_total"/>
                            </group>
                        </page>
                        <page string="Ghi chú">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vendor_bill_external" model="ir.actions.act_window">
        <field name="name">Hóa đơn Nhà cung cấp</field>
        <field name="res_model">store.vendor.bill</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_store_vendor_bill_list"/>
        <field name="domain">[]</field>
        <field name="context">{'group_by': 'partner_id'}</field>
    </record>

    <menuitem id="menu_vendor_bill_external_mer"
              name="Hóa đơn Nhà cung cấp"
              parent="account.menu_finance_payables"
              action="action_vendor_bill_external"
              sequence="10"/>
</odoo>
