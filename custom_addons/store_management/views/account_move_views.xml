<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: Thêm thông tin Cửa hàng vào Form Hóa đơn -->
    <record id="view_move_form_inherit_store_link" model="ir.ui.view">
        <field name="name">account.move.form.inherit.store.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="store_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Ẩn menu Thanh toán (Payments) và các mục không liên quan Mer -->
    <record id="account.menu_action_account_payments_payable" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_action_move_in_invoice_type" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_finance_receivables" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="account.menu_finance_entries" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Định nghĩa Hành động (Actions) sạch sẽ -->
    <record id="action_vendor_bill_external" model="ir.actions.act_window">
        <field name="name">Hóa đơn Nhà cung cấp</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('move_type', '=', 'in_invoice')]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
    </record>

    <!-- Cấu trúc Menu -->
    <menuitem id="menu_vendor_bill_external_mer" name="Hóa đơn Nhà cung cấp" 
              parent="account.menu_finance_payables" action="action_vendor_bill_external" sequence="10"/>

</odoo>
