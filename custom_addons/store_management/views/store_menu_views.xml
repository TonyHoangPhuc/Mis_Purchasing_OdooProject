<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem
        id="menu_store_root"
        name="Store"
        web_icon="stock,static/description/icon.png"
        sequence="35"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_catalog"
        name="Danh mục cửa hàng"
        parent="store_management.menu_store_root"
        action="store_management.action_store_stores"
        sequence="10"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_sales"
        name="Bán hàng"
        parent="store_management.menu_store_root"
        action="store_management.action_store_sales_orders"
        sequence="20"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_pr"
        name="Gửi yêu cầu PR"
        parent="store_management.menu_store_root"
        action="store_management.action_store_purchase_requests"
        sequence="30"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_inventory_root"
        name="Danh mục kho hàng"
        parent="store_management.menu_store_root"
        sequence="40"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_inventory_lines"
        name="Tồn kho và định mức theo cửa hàng"
        parent="store_management.menu_store_inventory_root"
        action="store_management.action_store_product_lines"
        sequence="10"
        groups="store_management.group_store_user"
    />

    <record id="action_store_receipts" model="ir.actions.act_window">
        <field name="name">Nhận hàng và QC theo cửa hàng</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="warehouse_management.view_receiving_qc_tree"/>
        <field name="search_view_id" ref="warehouse_management.view_receiving_qc_search"/>
        <field name="domain">['|', '&amp;', ('picking_type_code', '=', 'incoming'), ('picking_type_id.warehouse_id.mis_role', '=', 'store'), '&amp;', ('picking_type_code', '=', 'internal'), ('location_dest_id.warehouse_id.mis_role', '=', 'store')]</field>
        <field name="context">{'search_default_group_receiving_store': 1}</field>
    </record>

    <menuitem
        id="menu_store_receipts"
        name="Nhận hàng và QC"
        parent="store_management.menu_store_inventory_root"
        action="store_management.action_store_receipts"
        sequence="20"
        groups="store_management.group_store_user"
    />
</odoo>
