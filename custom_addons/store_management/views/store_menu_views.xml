<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem
        id="menu_store_root"
        name="Cửa hàng"
        web_icon="stock,static/description/icon.png"
        sequence="35"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_catalog"
        name="Danh mục cửa hàng"
        parent="store_management.menu_store_root"
        action="store_management.action_store_stores"
        sequence="10"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_sales"
        name="Bán hàng"
        parent="store_management.menu_store_root"
        action="store_management.action_store_sales_orders"
        sequence="20"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_pr"
        name="Gửi yêu cầu PR"
        parent="store_management.menu_store_root"
        action="store_management.action_store_purchase_requests"
        sequence="30"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_inventory_root"
        name="Kho cửa hàng"
        parent="store_management.menu_store_root"
        sequence="40"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_inventory_lines"
        name="Tồn kho và định mức theo cửa hàng"
        parent="store_management.menu_store_inventory_root"
        action="store_management.action_store_product_lines"
        sequence="10"
        groups="store_management.group_store_user"
    />

    <record id="action_store_receipts_pending" model="ir.actions.act_window">
        <field name="name">Đơn chờ nhận và QC</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="warehouse_management.view_receiving_qc_search"/>
        <field name="domain">[('location_dest_id.warehouse_id.mis_role', '=', 'store'), ('state', 'not in', ('done', 'cancel'))]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_store_receipts_history" model="ir.actions.act_window">
        <field name="name">Lịch sử giao nhận</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="warehouse_management.view_receiving_qc_tree"/>
        <field name="search_view_id" ref="warehouse_management.view_receiving_qc_search"/>
        <field name="domain">[('location_dest_id.warehouse_id.mis_role', '=', 'store'), ('state', 'in', ('done', 'cancel'))]</field>
        <field name="context">{'search_default_group_month': 1}</field>
    </record>

    <menuitem
        id="menu_store_receipts_pending"
        name="Đơn chờ nhận và QC"
        parent="store_management.menu_store_inventory_root"
        sequence="20"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_receipts_pending_action"
        name="Đơn hàng cần nhận"
        parent="store_management.menu_store_receipts_pending"
        action="store_management.action_store_receipts_pending"
        sequence="10"
        groups="store_management.group_store_user"
    />

    <menuitem
        id="menu_store_receipts_history"
        name="Lịch sử giao nhận"
        parent="store_management.menu_store_inventory_root"
        action="store_management.action_store_receipts_history"
        sequence="25"
        groups="store_management.group_store_user"
    />

    <record id="action_store_receipts_pending_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="store_management.view_warehouse_receiving_qc_kanban"/>
        <field name="act_window_id" ref="store_management.action_store_receipts_pending"/>
    </record>

    <record id="action_store_receipts_pending_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="warehouse_management.view_receiving_qc_tree"/>
        <field name="act_window_id" ref="store_management.action_store_receipts_pending"/>
    </record>
</odoo>
