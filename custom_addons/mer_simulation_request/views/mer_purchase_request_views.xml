<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mer_purchase_request_tree" model="ir.ui.view">
        <field name="name">mer.purchase.request.tree</field>
        <field name="model">mer.purchase.request</field>
        <field name="arch" type="xml">
            <list default_order="id desc">
                <field name="name"/>
                <field name="date_request"/>
                <field name="requester_id"/>
                <field name="warehouse_id"/>
                <field name="source_warehouse_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="purchase_count"/>
                <field name="allocation_plan_count"/>
            </list>
        </field>
    </record>

    <record id="view_mer_purchase_request_form" model="ir.ui.view">
        <field name="name">mer.purchase.request.form</field>
        <field name="model">mer.purchase.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_submit"
                        type="object"
                        string="Gửi yêu cầu"
                        class="oe_highlight"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_send_to_manager"
                        type="object"
                        string="Trình duyệt"
                        invisible="state not in ['draft', 'submitted']"
                    />
                    <button
                        name="action_approve"
                        type="object"
                        string="Duyệt"
                        class="btn-success"
                        groups="mer_simulation_request.group_mer_request_manager"
                        invisible="state != 'to_approve'"
                    />
                    <button
                        name="action_reject"
                        type="object"
                        string="Từ chối"
                        class="btn-secondary"
                        groups="mer_simulation_request.group_mer_request_manager"
                        invisible="state not in ['submitted', 'to_approve', 'approved']"
                    />
                    <button
                        name="action_create_po"
                        type="object"
                        string="Tạo chứng từ cung ứng"
                        class="btn-primary"
                        invisible="state != 'approved'"
                    />
                    <button
                        name="action_draft"
                        type="object"
                        string="Đặt lại nháp"
                        invisible="state in ['draft', 'po_created']"
                    />
                    <button
                        name="action_cancel"
                        type="object"
                        string="Hủy"
                        invisible="state in ['cancel', 'po_created']"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,submitted,to_approve,approved,po_created,rejected,cancel"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="purchase_count" widget="statinfo" string="Đơn mua"/>
                        </button>
                        <button name="action_view_allocation_plans" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="allocation_plan_count" widget="statinfo" string="Kế hoạch phân bổ"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_request"/>
                            <field name="requester_id" readonly="state != 'draft'"/>
                            <field name="approver_id" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="warehouse_id" readonly="state != 'draft'"/>
                            <field name="source_warehouse_id" readonly="state != 'draft'"/>
                            <field name="request_partner_id" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="state == 'po_created'"/>
                            <field name="allow_internal_fulfillment" readonly="state == 'po_created'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng hàng">
                            <field name="line_ids" nolabel="1" readonly="state not in ['draft', 'submitted']">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="procurement_preference"/>
                                    <field name="suggested_supply_method" readonly="1"/>
                                    <field name="resolved_supply_method" readonly="1"/>
                                    <field name="available_internal_qty" readonly="1"/>
                                    <field name="suggested_partner_id" readonly="1"/>
                                    <field name="partner_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú">
                            <field name="note" placeholder="Nhập ghi chú nghiệp vụ hoặc nội dung phê duyệt..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_mer_purchase_request_search" model="ir.ui.view">
        <field name="name">mer.purchase.request.search</field>
        <field name="model">mer.purchase.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="requester_id"/>
                <field name="warehouse_id"/>
                <field name="partner_id"/>
                <filter name="my_requests" string="Yêu cầu của tôi" domain="[('requester_id', '=', uid)]"/>
                <filter name="to_approve" string="Chờ duyệt" domain="[('state', '=', 'to_approve')]"/>
                <filter name="approved" string="Đã duyệt" domain="[('state', '=', 'approved')]"/>
                <filter name="processed" string="Đã xử lý" domain="[('state', '=', 'po_created')]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="Trạng thái" domain="[]" context="{'group_by': 'state'}"/>
                    <filter name="group_requester" string="Người yêu cầu" domain="[]" context="{'group_by': 'requester_id'}"/>
                    <filter name="group_warehouse" string="Kho nhận" domain="[]" context="{'group_by': 'warehouse_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mer_purchase_request" model="ir.actions.act_window">
        <field name="name">MER Requests</field>
        <field name="res_model">mer.purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mer_purchase_request_search"/>
    </record>

    <menuitem
        id="menu_mer_root"
        name="Mer"
        sequence="35"
        groups="mer_simulation_request.group_mer_request_user"
    />
    <menuitem
        id="menu_mer_request"
        name="MER Requests"
        parent="mer_simulation_request.menu_mer_root"
        action="mer_simulation_request.action_mer_purchase_request"
        sequence="10"
        groups="mer_simulation_request.group_mer_request_user"
    />

    <record id="view_purchase_order_form_inherit_mer_request" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.mer.request</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="mer_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_supply_chain_allocation_plan_form_inherit_mer_request" model="ir.ui.view">
        <field name="name">supply.chain.allocation.plan.form.inherit.mer.request</field>
        <field name="model">supply.chain.allocation.plan</field>
        <field name="inherit_id" ref="supply_chain_management.view_supply_chain_allocation_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='planned_date']" position="after">
                <field name="mer_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_form_inherit_mer_request" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.mer.request</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="mer_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
