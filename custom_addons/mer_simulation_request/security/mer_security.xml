<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_mer_simulation" model="ir.module.category">
        <field name="name">MER Simulation</field>
        <field name="sequence">36</field>
    </record>

    <record id="privilege_mer_simulation" model="res.groups.privilege">
        <field name="name">MER Simulation</field>
        <field name="category_id" ref="mer_simulation_request.module_category_mer_simulation"/>
        <field name="sequence">36</field>
    </record>

    <record id="group_mer_request_user" model="res.groups">
        <field name="name">MER Request User</field>
        <field name="privilege_id" ref="mer_simulation_request.privilege_mer_simulation"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_mer_request_manager" model="res.groups">
        <field name="name">MER Request Manager</field>
        <field name="privilege_id" ref="mer_simulation_request.privilege_mer_simulation"/>
        <field name="implied_ids" eval="[(4, ref('mer_simulation_request.group_mer_request_user')), (4, ref('purchase.group_purchase_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
