<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_supplier_management" model="ir.module.category">
        <field name="name">Supplier Management</field>
        <field name="sequence">35</field>
    </record>

    <record id="privilege_supplier_management" model="res.groups.privilege">
        <field name="name">Supplier Management</field>
        <field name="category_id" ref="module_category_supplier_management"/>
        <field name="sequence">35</field>
    </record>

    <record id="group_supplier_performance_user" model="res.groups">
        <field name="name">Supplier Performance User</field>
        <field name="privilege_id" ref="privilege_supplier_management"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <record id="group_supplier_performance_manager" model="res.groups">
        <field name="name">Supplier Performance Manager</field>
        <field name="privilege_id" ref="privilege_supplier_management"/>
        <field name="implied_ids" eval="[(4, ref('group_supplier_performance_user')), (4, ref('purchase.group_purchase_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
