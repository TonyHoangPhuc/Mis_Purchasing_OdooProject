<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_mer_purchase_request" model="ir.sequence">
        <field name="name">Merchandise Purchase Request</field>
        <field name="code">mer.purchase.request</field>
        <field name="prefix">PR/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_mer_discrepancy_report" model="ir.sequence">
        <field name="name">Merchandise Discrepancy Report</field>
        <field name="code">mer.discrepancy.report</field>
        <field name="prefix">DR/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
