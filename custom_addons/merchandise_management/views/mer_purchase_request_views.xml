<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List: Chi tiết sản phẩm PR -->
    <record id="view_mer_purchase_request_line_tree" model="ir.ui.view">
        <field name="name">mer.purchase.request.line.list</field>
        <field name="model">mer.purchase.request.line</field>
        <field name="arch" type="xml">
            <list string="Chi tiết sản phẩm" editable="bottom">
                <field name="product_id" string="Sản phẩm"/>
                <field name="product_qty" string="Số lượng"/>
                <field name="product_uom_id" string="Đơn vị" groups="uom.group_uom"/>
                <field name="price_unit" string="Đơn giá dự kiến"/>
                <field name="price_subtotal" string="Thành tiền" sum="Tổng tiền"/>
            </list>
        </field>
    </record>

    <!-- Form: Yêu cầu mua hàng (PR) -->
    <record id="view_mer_purchase_request_form" model="ir.ui.view">
        <field name="name">mer.purchase.request.form</field>
        <field name="model">mer.purchase.request</field>
        <field name="arch" type="xml">
            <form string="Yêu cầu mua hàng Merchandise">
                <header>
                    <button name="action_submit" string="Gửi đi" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_send_to_manager" string="Trình Quản lý" type="object" class="btn-info" invisible="state != 'submitted'" groups="merchandise_management.group_merchandise_user"/>
                    <button name="action_approve" string="Phê duyệt" type="object" class="btn-success" invisible="state != 'to_approve'" groups="merchandise_management.group_merchandise_manager"/>
                    <button name="action_reject" string="Từ chối" type="object" class="btn-danger" invisible="state not in ['submitted', 'to_approve']" groups="merchandise_management.group_merchandise_manager"/>
                    <button name="action_create_po" string="Tạo PO" type="object" class="btn-primary" invisible="state != 'approved'" groups="merchandise_management.group_merchandise_manager"/>
                    <button name="action_done" string="Hoàn tất" type="object" class="btn-success" invisible="state not in ['approved', 'po_created']" groups="merchandise_management.group_merchandise_manager"/>
                    <button name="action_draft" string="Chuyển về nháp" type="object" invisible="state not in ['rejected', 'cancel']"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state not in ['draft', 'submitted']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,to_approve,approved,po_created,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="purchase_order_count == 0">
                            <field name="purchase_order_count" widget="statinfo" string="Đơn PO"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" string="Người tạo" readonly="1"/>
                            <field name="warehouse_id" string="Cửa hàng" required="1"/>
                            <field name="company_partner_id" invisible="1"/>
                            <field
                                name="partner_id"
                                string="Kho tổng / NCC"
                                required="1"
                                domain="['|', ('category_id.name', '=', 'NCC'), ('id', '=', company_partner_id)]"
                            />
                            <field name="date_request" string="Ngày yêu cầu"/>
                        </group>
                        <group>
                            <field name="manager_id" string="Người duyệt" readonly="1"/>
                            <field name="payment_term_id" string="Điều khoản thanh toán" 
                                   readonly="state in ['done', 'cancel']" 
                                   groups="merchandise_management.group_merchandise_user"/>
                        </group>
                    </group>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="amount_total" string="Tổng tiền dự kiến" widget="monetary" readonly="1" decoration-bf="1"/>
                    </group>
                    <div class="clearfix"/>
                    <div class="row" invisible="context.get('from_store_menu')">
                        <div class="col-12">
                            <field name="x_mer_budget_info" nolabel="1" widget="html" class="mb-3"/>
                        </div>
                    </div>
                    <notebook>
                        <page string="Sản phẩm" name="lines">
                            <!-- O2M: Chi tiết sản phẩm -->
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_qty" string="Số lượng yêu cầu"/>
                                    <field name="product_uom_id" readonly="1"/>
                                    <field name="price_unit" string="Đơn giá dự kiến"/>
                                    <field name="price_subtotal" string="Thành tiền" sum="Tổng tiền"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="notes" placeholder="Nhập ghi chú thêm..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List: Danh sách các PR -->
    <record id="view_mer_purchase_request_tree" model="ir.ui.view">
        <field name="name">mer.purchase.request.list</field>
        <field name="model">mer.purchase.request</field>
        <field name="arch" type="xml">
            <list string="Yêu cầu mua hàng Merchandise" sample="1">
                <field name="name" string="Mã yêu cầu" decoration-bf="1"/>
                <field name="warehouse_id" string="Cửa hàng"/>
                <field name="user_id" string="Người tạo"/>
                <field name="date_request" string="Ngày yêu cầu"/>
                <field name="purchase_order_count" string="Số PO" optional="show"/>
                <field name="amount_total" string="Tổng tiền" widget="monetary" sum="Tổng cộng" decoration-bf="1"/>
                <field name="state" string="Trạng thái" widget="badge" decoration-info="state == 'submitted'" decoration-success="state == 'approved' or state == 'done'" decoration-warning="state == 'po_created'"/>
            </list>
        </field>
    </record>

    <!-- 4. Action -->
    <record id="action_mer_purchase_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu mua hàng (PR)</field>
        <field name="res_model">mer.purchase.request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="merchandise_management.view_mer_purchase_request_kanban"/>
        <field name="search_view_id" ref="merchandise_management.view_mer_purchase_request_search_enhanced"/>
    </record>
</odoo>
