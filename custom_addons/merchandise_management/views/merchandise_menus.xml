<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_merchandise_root"
              name="Merchandise"
              web_icon="purchase,static/description/icon.png"
              groups="merchandise_management.group_merchandise_user"
              sequence="10"/>

    <menuitem id="purchase.menu_purchase_root" active="False"/>

    <menuitem id="menu_merchandise_dashboard"
              name="Tổng quan"
              parent="menu_merchandise_root"
              action="action_merchandise_dashboard"
              sequence="1"/>

    <menuitem id="menu_merchandise_purchase_orders"
              name="Quản lý PO"
              parent="menu_merchandise_root"
              action="action_mer_po_management"
              sequence="5"/>

    <menuitem id="menu_merchandise_requests"
              name="Yêu cầu PR"
              parent="menu_merchandise_root"
              sequence="10"/>

    <record id="menu_merchandise_requests" model="ir.ui.menu">
        <field name="action" eval="False"/>
    </record>

    <menuitem id="menu_merchandise_requests_pending"
              name="PR chờ duyệt"
              parent="menu_merchandise_requests"
              action="action_mer_purchase_request_pending"
              sequence="1"/>

    <menuitem id="menu_merchandise_requests_processing"
              name="PR đang xử lý"
              parent="menu_merchandise_requests"
              action="action_mer_purchase_request_processing"
              sequence="2"/>

    <menuitem id="menu_merchandise_requests_done"
              name="PR hoàn tất"
              parent="menu_merchandise_requests"
              action="action_mer_purchase_request_done"
              sequence="3"/>

    <menuitem id="menu_merchandise_promotion"
              name="Khuyến mãi"
              parent="menu_merchandise_root"
              action="action_mer_promotion"
              sequence="15"/>

    <menuitem id="menu_merchandise_discrepancy"
              name="Báo cáo sai lệch"
              parent="menu_merchandise_root"
              groups="merchandise_management.group_merchandise_user"
              sequence="20"/>

    <menuitem id="menu_merchandise_discrepancy_lack"
              name="Báo cáo thiếu hàng"
              parent="menu_merchandise_discrepancy"
              action="action_mer_discrepancy_report_shortage"
              groups="merchandise_management.group_merchandise_user"
              sequence="1"/>

    <menuitem id="menu_merchandise_discrepancy_excess"
              name="Báo cáo nhận dư hàng"
              parent="menu_merchandise_discrepancy"
              action="action_mer_discrepancy_report_overage"
              groups="merchandise_management.group_merchandise_user"
              sequence="2"/>

    <menuitem id="menu_merchandise_discrepancy_damaged"
              name="Báo cáo hàng lỗi"
              parent="menu_merchandise_discrepancy"
              action="action_mer_discrepancy_report_damaged"
              groups="merchandise_management.group_merchandise_user"
              sequence="3"/>

    <menuitem id="menu_merchandise_products"
              name="Sản phẩm"
              parent="menu_merchandise_root"
              action="product.product_template_action_all"
              sequence="30"/>

    <menuitem id="menu_merchandise_config"
              name="Cấu hình"
              parent="menu_merchandise_root"
              sequence="100"/>
</odoo>
