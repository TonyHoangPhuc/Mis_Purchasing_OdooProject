<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mer_purchase_budget_tree" model="ir.ui.view">
        <field name="name">mer.purchase.budget.list</field>
        <field name="model">mer.purchase.budget</field>
        <field name="arch" type="xml">
            <list string="Ngân sách Merchandise">
                <field name="currency_id" column_invisible="True"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="budget_amount" sum="Tổng ngân sách"/>
                <field name="spent_amount" string="Đã thực chi" sum="Tổng đã xài"/>
                <field name="committed_amount" string="Đã cam kết" sum="Tổng cam kết"/>
                <field name="remaining_amount" string="Còn lại thực tế" sum="Tổng còn lại" decoration-danger="remaining_amount &lt; 0" decoration-success="remaining_amount &gt; 0"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="view_mer_purchase_budget_form" model="ir.ui.view">
        <field name="name">mer.purchase.budget.form</field>
        <field name="model">mer.purchase.budget</field>
        <field name="arch" type="xml">
            <form string="Ngân sách Merchandise">
                <header>
                    <button name="action_activate" string="Kích hoạt" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Đóng ngân sách" type="object" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ví dụ: Ngân sách Thực phẩm - Tháng 04/2026"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="budget_amount"/>
                        </group>
                        <group>
                            <label for="date_from" string="Thời gian áp dụng"/>
                            <div class="o_row">
                                <field name="date_from" widget="daterange" options="{'related_end_date': 'date_to'}"/>
                                <span>đến</span>
                                <field name="date_to" widget="daterange" options="{'related_start_date': 'date_from'}"/>
                            </div>
                        </group>
                    </group>
                    <group string="Theo dõi sử dụng">
                        <group>
                            <field name="spent_amount" string="Đã thực chi (PO)"/>
                            <field name="committed_amount" string="Đã cam kết (PR)"/>
                            <field name="remaining_amount" string="Còn lại thực tế" decoration-bf="1" decoration-danger="remaining_amount &lt; 0" decoration-success="remaining_amount &gt; 0"/>
                        </group>
                        <group>
                             <div class="alert alert-info" role="alert">
                                <b>Giải thích:</b> <br/>
                                - <b>Đã thực chi:</b> Tổng giá trị từ các Đơn mua hàng (PO) đã xác nhận. <br/>
                                - <b>Đã cam kết:</b> Tổng giá trị từ các Yêu cầu (PR) đã duyệt nhưng chưa chuyển thành PO.
                            </div>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mer_purchase_budget" model="ir.actions.act_window">
        <field name="name">Ngân sách mua hàng</field>
        <field name="res_model">mer.purchase.budget</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
