<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form: Cấu hình Merchandise -->
    <record id="product_template_form_view_merchandise_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.merchandise</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div class="alert alert-danger mb-0" role="alert" invisible="x_mer_sku_lifecycle != 'discontinued'">
                    <b>CẢNH BÁO:</b> Sản phẩm này đã ngừng kinh doanh và bị chặn đặt hàng.
                </div>
                <div class="alert alert-warning mb-0" role="alert" invisible="x_mer_sku_lifecycle != 'phase_out'">
                    <b>LƯU Ý:</b> Sản phẩm đang trong giai đoạn xả kho (Phase-out).
                </div>
            </xpath>
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="x_mer_stop_ordering"/>
                    <label for="x_mer_stop_ordering"/>
                </span>
            </xpath>
            <xpath expr="//page[@name='general_information']//group" position="after">
                <group string="Chiến lược Merchandise" name="merchandise_strategy" invisible="context.get('from_store_menu')">
                    <group>
                        <field name="x_mer_sku_lifecycle" widget="radio" options="{'horizontal': true}"/>
                        <field name="x_mer_abc_classification" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <group>
                        <field name="x_mer_supply_route" widget="radio" options="{'horizontal': true}"/>
                        <field name="x_mer_stop_ordering" widget="boolean_toggle" class="text-danger"/>
                    </group>
                </group>
                <group string="Khuyến mãi &amp; Hàng cận hạn" name="merchandise_promo" invisible="context.get('from_store_menu')">
                    <group>
                        <field name="current_promotion_price" widget="monetary" invisible="current_promotion_price == 0" class="text-success" string="Giá khuyến mãi"/>
                        <field name="current_promotion_line_id" invisible="not current_promotion_line_id"/>
                    </group>
                    <group>
                        <field name="x_mer_expiry_days"/>
                        <field name="x_mer_expiry_discount"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
