<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_merchandise_management_category" model="ir.module.category">
        <field name="name">Quản lý Merchandise</field>
        <field name="description">Quản lý nghiệp vụ Merchandise</field>
        <field name="sequence">100</field>
    </record>

    <!-- Odoo 19 Security: Add Privilege layer -->
    <record id="module_merchandise_management_privilege" model="res.groups.privilege">
        <field name="name">Bộ phận Merchandise</field>
        <field name="category_id" ref="module_merchandise_management_category"/>
    </record>

    <record id="group_merchandise_user" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="privilege_id" ref="module_merchandise_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_merchandise_manager" model="res.groups">
        <field name="name">Quản lý</field>
        <field name="privilege_id" ref="module_merchandise_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('group_merchandise_user'))]"/>
    </record>
</odoo>
